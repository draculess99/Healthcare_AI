# Copy to .env for local development. Never commit the real .env file.

# Optional LLM committee providers. Internal Expert System mode needs no key.
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_MODEL=openai/gpt-oss-20b

# Internal Flask/Waitress API settings.
BEDFLOW_API_HOST=127.0.0.1
BEDFLOW_API_PORT=5005
BEDFLOW_API_URL=http://127.0.0.1:5005/api
BEDFLOW_USE_WAITRESS=true

# Local Streamlit port. Cloud platforms normally inject PORT automatically.
BEDFLOW_DASHBOARD_PORT=8501

# Stage 8 local demonstration authentication.
# Set a long random secret outside local-only development.
BEDFLOW_AUTH_SECRET=replace-with-a-long-random-secret
BEDFLOW_DEMO_PASSWORD=BedFlowDemo!
BEDFLOW_TOKEN_MAX_AGE_SECONDS=28800


# Mutable JSON persistence.
# Local default: bundled database directory.
# Railway/Docker recommendation: set /data and attach a persistent volume at /data.
# BEDFLOW_DATA_DIR=/data

# Stage 10A structured logging and readiness.
BEDFLOW_LOG_LEVEL=INFO
BEDFLOW_LOG_FORMAT=json
# Set true in a public deployment to fail readiness when the demo secret is active.
BEDFLOW_REQUIRE_STRONG_SECRETS=false
