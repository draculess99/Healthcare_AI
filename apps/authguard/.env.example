# Optional explanation providers. Local Expert System mode needs no key.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional external de-identified case feed.
AUTHGUARD_LIVE_DATA_URL=
AUTHGUARD_LIVE_DATA_BEARER_TOKEN=

# Control-tower defaults (overridden by root start.sh).
AUTHGUARD_API_PORT=5105
AUTHGUARD_DATA_DIR=/tmp/authguard-data
